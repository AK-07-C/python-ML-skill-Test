    "import numpy as np\n",
    "\n",
    "A = np.array([[2, 3],\n",
    "              [1, 2]])\n",
    "\n",
    "b = np.array([8, 5])\n",
    "\n",
    "x = np.linalg.solve(A, b)\n",
    "\n",
    "print(\"Solution vector x:\")\n",
    "print(x)"
